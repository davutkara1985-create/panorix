rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function sameOrganization(orgId) {
      return signedIn() && request.auth.token.organizationId == orgId;
    }

    function privileged() {
      return signedIn() && request.auth.token.role in ['super_admin', 'admin', 'manager'];
    }

    function canUpload() {
      return signedIn()
        && request.auth.token.role in [
          'super_admin', 'admin', 'manager', 'sales_manager', 'sales_rep',
          'accounting', 'operations_manager', 'operations_staff', 'field_staff'
        ];
    }

    function allowedContent() {
      return request.resource == null
        || request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches(
          'image/.*|application/pdf|application/msword|application/vnd.openxmlformats-officedocument.*|application/vnd.ms-excel|text/.*'
        );
    }

    match /organizations/{orgId}/{module}/{recordId}/{fileName} {
      allow read: if sameOrganization(orgId);
      allow create, update: if sameOrganization(orgId) && canUpload() && allowedContent();
      allow delete: if sameOrganization(orgId) && privileged();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
