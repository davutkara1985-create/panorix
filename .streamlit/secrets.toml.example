# Bu dosya yalnızca örnektir. Gerçek değerleri GitHub'a yüklemeyin.
# Değerleri Streamlit Cloud > Manage app > Settings > Secrets alanına girin.

# İlk yönetici hesabı uygulama açıldığında otomatik oluşturulur.
# INITIAL_ADMIN_PASSWORD değerini yalnız Streamlit Secrets alanına yazın.
# İlk başarılı girişten sonra bu parola satırını Secrets'tan silebilirsiniz.
INITIAL_ADMIN_EMAIL = "davutkara1985@gmail.com"
INITIAL_ADMIN_PASSWORD = ""
INITIAL_ADMIN_NAME = "Davut Kara"
INITIAL_ORGANIZATION_NAME = "PANORIX"
INITIAL_ORGANIZATION_ID = "panorix"

SESSION_TIMEOUT_MINUTES = 60
APP_PUBLIC_URL = "https://UYGULAMA-ADINIZ.streamlit.app"

[firebase_web]
api_key = ""
auth_domain = "PROJE-ID.firebaseapp.com"
project_id = "PROJE-ID"
storage_bucket = "PROJE-ID.firebasestorage.app"
messaging_sender_id = ""
app_id = ""
measurement_id = ""

[firebase_service_account]
type = "service_account"
project_id = "PROJE-ID"
private_key_id = ""
private_key = "FIREBASE_JSON_DOSYASINDAKI_PRIVATE_KEY_DEGERI"
client_email = "firebase-adminsdk-xxxxx@PROJE-ID.iam.gserviceaccount.com"
client_id = ""
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = ""
universe_domain = "googleapis.com"
